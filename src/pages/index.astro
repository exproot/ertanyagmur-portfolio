---
import projects from '../data/projects.json';
import experience from '../data/experience.json';
import education from '../data/education.json';
import header from '../data/header.json';
---
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/ertanyagmur-portfolio/favicon.svg" />
    <meta name="viewport" content="width=device-width" />
    <meta name="theme-color" content="#2563eb" />
    <title>{header.name} Yağmur - {header.title}</title>
    <link rel="stylesheet" href="/ertanyagmur-portfolio/style.css" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  </head>
  <body>
    <header>
      <div class="header-row">
        <nav>
          <ul>
            {header.navigation.map((nav) => (
              <li><a href={nav.href}>{nav.text}</a></li>
            ))}
          </ul>
        </nav>
      </div>
    </header>
    <main>
      <section class="intro compact-intro">
        <div class="intro-row align-split">
          <div class="intro-text align-left">
            <h1>Hi, I'm <span class="highlight">{header.name}</span> 👋</h1>
            <p>{header.introText}</p>
            <p class="location">Based in {header.location}</p>
            <button id="copy-email" data-email={header.email}>Copy Email</button>
            <span id="email-feedback" style="display:none;">Email Copied!</span>
          </div>
          <div class="intro-avatar-col align-right">
            <img src="/ertanyagmur-portfolio/assets/avatar-placeholder.png" alt="Your Avatar" class="avatar large-avatar" />
            <div class="social-icons social-icons-below">
              {header.social.map((social) => (
                <a href={social.url} class="social-icon" target="_blank" aria-label={social.platform}>
                  {social.icon === 'linkedin' && (
                    <svg viewBox="0 0 24 24" fill="currentColor" width="24" height="24"><path d="M5 3c0 1.062-.71 1.976-2.001 1.976C1.784 4.976 1 4.114 1 3.052C1 1.962 1.76 1 3 1s1.976.91 2 2M1 19V6h4v13zm6-8.556c0-1.545-.051-2.836-.102-3.951h3.594l.178 1.723h.076c.506-.811 1.746-2 3.822-2C17.1 6.216 19 7.911 19 11.558V19h-4v-6.861c0-1.594-.607-2.81-2-2.81c-1.062 0-1.594.86-1.873 1.569c-.102.254-.127.608-.127.963V19H7z"/></svg>
                  )}
                  {social.icon === 'github' && (
                    <svg viewBox="0 0 24 24" fill="currentColor" width="24" height="24"><path d="M12 0c-6.63 0-12 5.37-12 12 0 5.3 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61-.546-1.387-1.333-1.756-1.333-1.756-1.09-.745.083-.729.083-.729 1.205.085 1.84 1.237 1.84 1.237 1.07 1.834 2.807 1.304 3.492.997.108-.775.418-1.305.762-1.605-2.665-.305-5.466-1.332-5.466-5.93 0-1.31.468-2.38 1.236-3.22-.124-.303-.535-1.523.117-3.176 0 0 1.008-.322 3.3 1.23.96-.267 1.98-.399 3-.404 1.02.005 2.04.137 3 .404 2.29-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.873.12 3.176.77.84 1.235 1.91 1.235 3.22 0 4.61-2.803 5.625-5.475 5.92.43.37.823 1.102.823 2.222 0 1.606-.015 2.898-.015 3.293 0 .32.216.694.825.576 4.765-1.587 8.2-6.086 8.2-11.384 0-6.63-5.373-12-12-12z"/></svg>
                  )}
                  {social.icon === 'medium' && (
                    <svg viewBox="0 0 50 50" fill="currentColor"> <path d="M15 12A13 13 0 1015 38 13 13 0 1015 12zM35.5 13c-3.59 0-6.5 5.373-6.5 12 0 1.243.102 2.441.292 3.568.253 1.503.662 2.879 1.192 4.065.265.593.56 1.138.881 1.627.642.978 1.388 1.733 2.202 2.201C34.178 36.811 34.827 37 35.5 37s1.322-.189 1.933-.539c.814-.468 1.56-1.223 2.202-2.201.321-.489.616-1.034.881-1.627.53-1.185.939-2.562 1.192-4.065C41.898 27.441 42 26.243 42 25 42 18.373 39.09 13 35.5 13zM45.5 14c-.259 0-.509.173-.743.495-.157.214-.307.494-.448.833-.071.169-.14.353-.206.551-.133.395-.257.846-.37 1.343-.226.995-.409 2.181-.536 3.497-.063.658-.112 1.349-.146 2.065C43.017 23.499 43 24.241 43 25s.017 1.501.051 2.217c.033.716.082 1.407.146 2.065.127 1.316.31 2.501.536 3.497.113.498.237.948.37 1.343.066.198.135.382.206.551.142.339.292.619.448.833C44.991 35.827 45.241 36 45.5 36c1.381 0 2.5-4.925 2.5-11S46.881 14 45.5 14z"></path></svg>
                  )}
              </a>
              ))}
            </div>
          </div>
        </div>
      </section>
      <hr class="divider" />
      <section class="projects" id="apps">
        <h2 class="projects-title">Projects</h2>
        {projects.map((project, idx) => (
          <div class="project-card" key={project.title} style={{'--card-bg': project.cardColor || undefined}}>
            <div class="project-info-card">
              <img src={project.appIcon} alt="App Icon" class="project-app-icon" />
              <div class="project-info-content">
                <div class="project-title">{project.title}</div>
                <div class="project-tech">{project.technologies.join(', ')}</div>
              </div>
              {project.appStoreUrl && (
                <a class="app-store-badge" href={project.appStoreUrl} target="_blank" rel="noopener">
                  <img src="/ertanyagmur-portfolio/assets/appstore.png" alt="Download on the App Store" />
                </a>
              )}
            </div>
            <h3 class="project-headline">{project.headline}</h3>
            <div class="project-screenshots-slider">
              <button class="slider-arrow left" aria-label="Scroll left" onclick="carouselScreenshots(this, -1)">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <polyline points="15,18 9,12 15,6"></polyline>
                </svg>
              </button>
              <div class="project-screenshots-row" data-index="0">
                {project.screenshots.map((src, i) => (
                  <img src={src} alt={`App Screenshot ${i+1}`} class={`project-mockup${i === 0 ? ' active' : ''}`} />
                ))}
              </div>
              <button class="slider-arrow right" aria-label="Scroll right" onclick="carouselScreenshots(this, 1)">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <polyline points="9,18 15,12 9,6"></polyline>
                </svg>
              </button>
            </div>
            <div class="project-badge-row">
              {project.badge && (
                <span class="project-badge">{project.badge}</span>
              )}
              <a class="project-learn-more" href={project.learnMoreUrl} target="_blank">Learn more →</a>
            </div>
          </div>
        ))}
      </section>
      <hr class="divider" />
      <section class="experience">
        <h2 class="experience-title">Experience</h2>
        {experience.map((item) => (
          <div class="experience-item" key={item.company + item.role}>
            <img src={item.logo} alt="Company Logo" />
            <div>
              <h3>{item.company}</h3>
              <p><strong>{item.role}</strong> | {item.dates}</p>
              <ul>
                {item.bullets.map((b) => <li>{b}</li>)}
              </ul>
            </div>
          </div>
        ))}
      </section>
      <hr class="divider" />
      <section class="education">
        <h2 class="education-title">Education</h2>
        {education.map((item) => (
          <div class="education-item" key={item.school + item.degree}>
            <img src={item.logo} alt="School Logo" />
            <div>
              <h3>{item.school}</h3>
              <p>{item.degree}</p>
              <ul>
                {item.bullets.map((b) => <li>{b}</li>)}
              </ul>
            </div>
          </div>
        ))}
      </section>
    </main>
    <footer>
      <p>&copy; 2025 {header.name} Yağmur. All Rights Reserved.</p>
    </footer>
    <script src="/ertanyagmur-portfolio/script.js" is:inline></script>
  </body>
</html>
